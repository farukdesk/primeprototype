<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash screen / launch theme background -->
    <color name="launch_background">#1A1F36</color>
    <!-- FCM notification accent colour -->
    <color name="notification_color">#4F8EF7</color>

    <!-- Splash / Launch theme -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/launch_background</item>
        <item name="android:statusBarColor">@color/launch_background</item>
        <item name="android:navigationBarColor">@color/launch_background</item>
    </style>

    <!-- Normal theme applied after splash -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
